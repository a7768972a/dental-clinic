// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// المرضى
model Patient {
  id            String   @id @default(cuid())
  name          String
  phone         String
  email         String?
  dateOfBirth   DateTime?
  gender        String?  // male, female
  address       String?
  medicalNotes  String?
  allergies     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  appointments  Appointment[]
  teeth         ToothRecord[]
  invoices      Invoice[]
  queueEntries  QueueEntry[]
}

// المواعيد
model Appointment {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id])
  title         String
  serviceId     String?
  service       Service? @relation(fields: [serviceId], references: [id])
  startTime     DateTime
  endTime       DateTime
  status        String   @default("scheduled") // scheduled, confirmed, completed, cancelled, no-show
  notes         String?
  reminderSent  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([patientId])
  @@index([startTime])
}

// سجلات الأسنان (32 سناً)
model ToothRecord {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  toothNumber Int      // 1-32 (FDI notation)
  condition   String   @default("healthy") // healthy, decay, filling, implant, extracted, crown, root-canal
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([patientId, toothNumber])
  @@index([patientId])
}

// الخدمات والأسعار
model Service {
  id          String   @id @default(cuid())
  name        String
  nameAr      String   // Arabic name
  category    String?  // cleaning, restoration, surgery, cosmetic, orthodontics
  price       Float
  duration    Int      // in minutes
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  appointments Appointment[]
  invoiceItems InvoiceItem[]
}

// الفواتير
model Invoice {
  id           String   @id @default(cuid())
  invoiceNumber String  @unique
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id])
  status       String   @default("pending") // pending, paid, partially-paid, cancelled
  subtotal     Float    @default(0)
  discount     Float    @default(0)
  tax          Float    @default(0)
  total        Float    @default(0)
  paidAmount   Float    @default(0)
  dueDate      DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  items        InvoiceItem[]
  payments     Payment[]
  installmentPlan InstallmentPlan?
  
  @@index([patientId])
  @@index([createdAt])
}

// عناصر الفاتورة
model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float
  createdAt   DateTime @default(now())
  
  @@index([invoiceId])
}

// المدفوعات
model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // cash, card, transfer
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
  
  @@index([invoiceId])
}

// خطط التقسيط
model InstallmentPlan {
  id              String   @id @default(cuid())
  invoiceId       String   @unique
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  totalAmount     Float
  numberOfMonths  Int
  monthlyAmount   Float
  startDate       DateTime
  endDate         DateTime
  status          String   @default("active") // active, completed, cancelled, defaulted
  downPayment     Float    @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  installments    InstallmentPayment[]

  @@index([status])
}

// أقساط الدفع
model InstallmentPayment {
  id                String   @id @default(cuid())
  planId            String
  plan              InstallmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  installmentNumber Int
  amount            Float
  dueDate           DateTime
  paidDate          DateTime?
  paidAmount        Float    @default(0)
  status            String   @default("pending") // pending, paid, late, partial
  lateFee           Float    @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([planId])
  @@index([status])
  @@index([dueDate])
}

// النفقات
model Expense {
  id          String   @id @default(cuid())
  category    String   // salaries, supplies, rent, utilities, equipment, other
  description String
  amount      Float
  date        DateTime @default(now())
  reference   String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([date])
  @@index([category])
}

// صالة الانتظار
model QueueEntry {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  status      String   @default("waiting") // arrived, waiting, with-doctor, completed
  priority    Int      @default(0) // 0=normal, 1=urgent, 2=emergency
  checkInTime DateTime @default(now())
  calledTime  DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([checkInTime])
}

// الإعدادات
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// الإشعارات
model Notification {
  id          String   @id @default(cuid())
  type        String   // appointment, payment, automation, system
  title       String
  message     String
  data        String?  // JSON string for additional data
  read        Boolean  @default(false)
  source      String?  // n8n, system, whatsapp
  createdAt   DateTime @default(now())
  
  @@index([read])
  @@index([createdAt])
}

// سجلات الأتمتة (n8n webhooks)
model AutomationLog {
  id          String   @id @default(cuid())
  type        String   // booking, reminder, confirmation
  source      String   // whatsapp, n8n, system
  payload     String   // JSON string
  status      String   // success, failed
  message     String?
  createdAt   DateTime @default(now())
  
  @@index([createdAt])
  @@index([type])
}
